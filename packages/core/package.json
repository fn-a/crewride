{
    "name": "@crewride/core",
    "version": "0.0.1",
    "description": "Shared types, hooks, and utilities for CrewRide AI Chat",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "peerDependencies": {
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
    },
    "devDependencies": {
        "@types/react": "^19.2.3",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.3",
        "vite": "^8.0.12",
        "vite-plugin-dts": "^5.0.0"
    },
    "license": "MIT"
}
